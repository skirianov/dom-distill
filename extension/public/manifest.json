{
    "manifest_version": 3,
    "name": "DOM Distill Agent",
    "version": "1.0.0",
    "description": "Browser-native AI agent using dom-distill",
    "permissions": [
        "sidePanel",
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "*://*/*"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "side_panel": {
        "default_path": "index.html"
    },
    "action": {
        "default_title": "Open Agent"
    }
}